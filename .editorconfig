# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Java source files
[*.java]
indent_size = 4
max_line_length = 160

# XML files (pom.xml, FXML, etc.)
[*.{xml,fxml}]
indent_size = 4
max_line_length = 120

# Properties files
[*.properties]
indent_size = 4

# CSS files
[*.css]
indent_size = 4
max_line_length = 120

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 4
end_of_line = lf

# Batch files
[*.{bat,cmd}]
indent_size = 4
end_of_line = crlf

# Maven wrapper
[mvnw]
end_of_line = lf

[mvnw.cmd]
end_of_line = crlf

# PlantUML files
[*.puml]
indent_size = 2
