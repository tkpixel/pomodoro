<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.signongroup.pomodoro.view.MainViewController"
           styleClass="bg-mesh"
           prefHeight="552.0" prefWidth="684.0">

    <!-- Sub-view content is loaded here dynamically -->
    <StackPane fx:id="contentContainer" />

    <!-- TopAppBar LAST = highest Z-order = always clickable -->
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" styleClass="glass-bar" StackPane.alignment="TOP_CENTER" maxHeight="80.0">
        <padding>
            <Insets left="24" right="24"/>
        </padding>
        <Button styleClass="fab-icon-button" onAction="#handleMinimize">
            <graphic>
                <FontIcon iconLiteral="fltfal-arrow-minimize-20" iconSize="24" styleClass="menu-icon"/>
            </graphic>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="MONOLITH" styleClass="font-manrope tracking-widest" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: -fx-primary; -fx-text-transform: uppercase;" />
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER" spacing="8">
            <Button styleClass="fab-icon-button" onAction="#handleOpenSettingsMenu">
                <graphic>
                    <FontIcon iconLiteral="fltral-line-horizontal-3-20" iconSize="24" styleClass="menu-icon"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

</StackPane>
