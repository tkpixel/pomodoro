<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.Group?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.signongroup.pomodoro.view.MiniTimerViewController"
           prefHeight="125.0" prefWidth="288.0"
           style="-fx-background-color: #0e0e0e;">

    <!-- Main Container -->
    <VBox spacing="0"
          style="-fx-background-color: #0e0e0e; -fx-background-radius: 8; -fx-border-color: rgba(73, 72, 71, 0.15); -fx-border-radius: 8; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 48, 0, 0, 24);">
        <padding>
            <Insets top="8" right="8" bottom="8" left="8"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <Label text="MONOLITH" style="-fx-font-family: 'Manrope'; -fx-font-size: 8px; -fx-font-weight: 800; -fx-text-fill: #adaaaa;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleMaximize" style="-fx-background-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                <graphic>
                    <FontIcon iconLiteral="fltral-arrow-maximize-20" iconSize="14" iconColor="#ff8f70" />
                </graphic>
            </Button>
        </HBox>

        <!-- Active Task Marquee -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
            <Label fx:id="taskLabel" text="MNL-482: REFACTOR KINETIC PHYSICS ENGINE" textOverrun="ELLIPSIS" maxWidth="214"
                   style="-fx-font-family: 'Inter'; -fx-font-size: 8px; -fx-font-weight: 600; -fx-text-fill: #ff8f70;"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <!-- Timer & Controls -->
        <HBox alignment="BOTTOM_LEFT">
            <!-- Timer Label -->
            <Label fx:id="timerLabel" text="25:00"
                   style="-fx-font-family: 'Manrope'; -fx-font-size: 36px; -fx-font-weight: 200; -fx-text-fill: #ffffff; -fx-padding: 0 0 -6 0;" />
            <Region HBox.hgrow="ALWAYS" />
            <!-- Controls Pill -->
            <HBox alignment="CENTER" spacing="8" styleClass="play-btn" style="-fx-padding: 6 12 6 12; -fx-background-radius: 9999;">
                <Button onAction="#handlePlayPause" style="-fx-background-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon fx:id="playIcon" iconLiteral="fltfmz-play-20" iconSize="16" iconColor="#101010" />
                    </graphic>
                </Button>
                <Button onAction="#handleStop" style="-fx-background-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="fltfmz-stop-20" iconSize="16" iconColor="#101010" />
                    </graphic>
                </Button>
            </HBox>
        </HBox>

    </VBox>
</StackPane>
