<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.signongroup.pomodoro.view.SettingsOverlayViewController"
           fx:id="overlayRoot"
           visible="false">

    <!-- Dark Blur Background -->
    <Region fx:id="backgroundRegion" styleClass="overlay-bg" onMouseClicked="#handleClose" />

    <!-- Bottom Sheet Content -->
    <VBox fx:id="bottomSheet" styleClass="settings-bottom-sheet" StackPane.alignment="BOTTOM_CENTER" alignment="TOP_CENTER" maxHeight="-Infinity" translateY="1000">

        <!-- Handle -->
        <Region styleClass="settings-handle">
            <VBox.margin>
                <Insets bottom="32" />
            </VBox.margin>
        </Region>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" styleClass="settings-header">
            <TextFlow>
                <Text text="Preferences&#10;" styleClass="settings-header-title-white" />
                <Text text="DURATION" styleClass="settings-header-title-orange" />
            </TextFlow>
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="fab-icon-button" onAction="#handleClose">
                <graphic>
                    <FontIcon iconLiteral="fltfal-dismiss-24" iconSize="24"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Stats Grid -->
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>

            <!-- Card 1: Focus Session -->
            <VBox styleClass="settings-card, settings-card-active" GridPane.columnIndex="0" GridPane.rowIndex="0" onMouseEntered="#handleCardHover" onMouseExited="#handleCardExit">
                <Label text="FOCUS SESSION" styleClass="settings-card-label" />
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="16">
                    <Button styleClass="settings-btn" onAction="#handleDecFocus">
                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                    </Button>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="focusSessionLabel" text="25" styleClass="settings-card-value" />
                        <Label text="MINUTES" styleClass="settings-card-unit" />
                    </VBox>
                    <Button styleClass="settings-btn" onAction="#handleIncFocus">
                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                    </Button>
                </HBox>
            </VBox>

            <!-- Card 2: Short Break -->
            <VBox styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="0" onMouseEntered="#handleCardHover" onMouseExited="#handleCardExit">
                <Label text="SHORT BREAK" styleClass="settings-card-label-muted" />
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="16">
                    <Button styleClass="settings-btn" onAction="#handleDecShortBreak">
                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                    </Button>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="shortBreakLabel" text="05" styleClass="settings-card-value" />
                        <Label text="MINUTES" styleClass="settings-card-unit" />
                    </VBox>
                    <Button styleClass="settings-btn" onAction="#handleIncShortBreak">
                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                    </Button>
                </HBox>
            </VBox>

            <!-- Card 3: Long Break -->
            <VBox styleClass="settings-card" GridPane.columnIndex="0" GridPane.rowIndex="1" onMouseEntered="#handleCardHover" onMouseExited="#handleCardExit">
                <Label text="LONG BREAK" styleClass="settings-card-label-muted" />
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="16">
                    <Button styleClass="settings-btn" onAction="#handleDecLongBreak">
                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                    </Button>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="longBreakLabel" text="15" styleClass="settings-card-value" />
                        <Label text="MINUTES" styleClass="settings-card-unit" />
                    </VBox>
                    <Button styleClass="settings-btn" onAction="#handleIncLongBreak">
                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                    </Button>
                </HBox>
            </VBox>

            <!-- Card 4: Session Count -->
            <VBox styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="1" onMouseEntered="#handleCardHover" onMouseExited="#handleCardExit">
                <Label text="MAX SESSION COUNT" styleClass="settings-card-label-muted" />
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="16">
                    <Button styleClass="settings-btn" onAction="#handleDecMaxSessions">
                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                    </Button>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="maxSessionsLabel" text="4" styleClass="settings-card-value" />
                        <Label text="SESSIONS" styleClass="settings-card-unit" />
                    </VBox>
                    <Button styleClass="settings-btn" onAction="#handleIncMaxSessions">
                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                    </Button>
                </HBox>
            </VBox>

        </GridPane>

    </VBox>

</StackPane>
