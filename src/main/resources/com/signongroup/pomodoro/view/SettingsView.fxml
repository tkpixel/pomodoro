<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.signongroup.pomodoro.view.SettingsViewController"
           styleClass="bg-mesh"
           prefHeight="884.0" prefWidth="570.0">

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;" hbarPolicy="NEVER">
        <VBox spacing="16" alignment="TOP_LEFT" maxWidth="600" style="-fx-padding: 120 24 160 24;">

            <!-- Page Title & Intro -->
            <VBox spacing="8" style="-fx-margin-bottom: 48;">
                <TextFlow>
                    <Text text="System Configuration " style="-fx-fill: -fx-on-surface; -fx-font-size: 24px; -fx-font-weight: 900; -fx-font-family: 'System', 'Manrope', sans-serif;" />
                    <Text text="SETTINGS" style="-fx-fill: #FF6B4A; -fx-font-size: 24px; -fx-font-style: italic; -fx-font-weight: bold; -fx-font-family: 'System', 'Manrope', sans-serif;" />
                </TextFlow>
                <Label text="Fine-tune your temporal workflow and external integrations through the kinetic interface." wrapText="true" style="-fx-text-fill: -fx-on-surface-variant; -fx-font-size: 14px; -fx-max-width: 400;"/>
            </VBox>

            <!-- Accordion Panels Container -->
            <VBox fx:id="accordionContainer" spacing="16">

                <!-- Panel 1: Duration Preferences -->
                <VBox styleClass="ghost-border, accordion-panel">

                    <!-- Header -->
                    <HBox onMouseClicked="#toggleDurationExpanded" alignment="CENTER_LEFT" styleClass="accordion-header">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <FontIcon fx:id="durationIcon" iconLiteral="fltfmz-timer-20" iconSize="24" styleClass="accordion-icon"/>
                        <Region prefWidth="16"/>
                        <Label text="DURATION PREFERENCES" styleClass="accordion-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon fx:id="durationExpandIcon" iconLiteral="fltral-chevron-down-20" iconSize="24" styleClass="accordion-expand-icon"/>
                    </HBox>

                    <!-- Content -->
                    <VBox fx:id="durationContent" spacing="24" styleClass="accordion-content">
                        <padding><Insets top="0" right="24" bottom="24" left="24"/></padding>

                        <!-- 2x2 Grid for Configuration Cards -->
                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>

                            <!-- Focus Duration Card -->
                            <VBox styleClass="settings-card-flat, ghost-border" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="FOCUS DURATION" styleClass="settings-card-flat-label" />
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="16">
                                    <Button styleClass="settings-btn" onAction="#handleDecFocus">
                                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                                    </Button>
                                    <Label fx:id="focusSessionLabel" text="25:00" styleClass="settings-card-flat-value" />
                                    <Button styleClass="settings-btn" onAction="#handleIncFocus">
                                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                                    </Button>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="MIN" styleClass="settings-card-flat-unit" />
                            </VBox>

                            <!-- Short Break Card -->
                            <VBox styleClass="settings-card-flat, ghost-border" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="SHORT BREAK" styleClass="settings-card-flat-label" />
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="16">
                                    <Button styleClass="settings-btn" onAction="#handleDecShortBreak">
                                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                                    </Button>
                                    <Label fx:id="shortBreakLabel" text="05:00" styleClass="settings-card-flat-value" />
                                    <Button styleClass="settings-btn" onAction="#handleIncShortBreak">
                                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                                    </Button>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="MIN" styleClass="settings-card-flat-unit" />
                            </VBox>

                            <!-- Long Break Card -->
                            <VBox styleClass="settings-card-flat, ghost-border" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="LONG BREAK" styleClass="settings-card-flat-label" />
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="16">
                                    <Button styleClass="settings-btn" onAction="#handleDecLongBreak">
                                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                                    </Button>
                                    <Label fx:id="longBreakLabel" text="15:00" styleClass="settings-card-flat-value" />
                                    <Button styleClass="settings-btn" onAction="#handleIncLongBreak">
                                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                                    </Button>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="MIN" styleClass="settings-card-flat-unit" />
                            </VBox>

                            <!-- Max Session Count Card -->
                            <VBox styleClass="settings-card-flat, ghost-border" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="MAX SESSION COUNT" styleClass="settings-card-flat-label" />
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="16">
                                    <Button styleClass="settings-btn" onAction="#handleDecMaxSessions">
                                        <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="18"/></graphic>
                                    </Button>
                                    <Label fx:id="maxSessionsLabel" text="4" styleClass="settings-card-flat-value" />
                                    <Button styleClass="settings-btn" onAction="#handleIncMaxSessions">
                                        <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="18"/></graphic>
                                    </Button>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="SESSIONS" styleClass="settings-card-flat-unit" />
                            </VBox>

                        </GridPane>

                        <!-- Auto-start Breaks Toggle -->
                        <HBox alignment="CENTER" styleClass="ghost-border" style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 12; -fx-padding: 16;">
                            <VBox alignment="CENTER_LEFT" spacing="4">
                                <Label text="Auto-start Breaks" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                                <Label text="SEQUENTIAL SESSION FLOW" style="-fx-font-size: 10px; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <StackPane fx:id="autoStartTogglePane" onMouseClicked="#toggleAutoStart" styleClass="toggle-track" prefWidth="48" prefHeight="24">
                                <Region fx:id="autoStartToggleThumb" styleClass="toggle-thumb" StackPane.alignment="CENTER_LEFT" maxWidth="16" maxHeight="16"/>
                            </StackPane>
                        </HBox>

                    </VBox>
                </VBox>

                <!-- Panel 2: Jira Connection -->
                <VBox styleClass="ghost-border, accordion-panel">

                    <!-- Header -->
                    <HBox onMouseClicked="#toggleJiraExpanded" alignment="CENTER_LEFT" styleClass="accordion-header">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <FontIcon fx:id="jiraIcon" iconLiteral="fltfal-arrow-sync-20" iconSize="24" styleClass="accordion-icon"/>
                        <Region prefWidth="16"/>
                        <Label text="JIRA CONNECTION" styleClass="accordion-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon fx:id="jiraExpandIcon" iconLiteral="fltral-chevron-down-20" iconSize="24" styleClass="accordion-expand-icon"/>
                    </HBox>

                    <!-- Content -->
                    <VBox fx:id="jiraContent" spacing="24" styleClass="accordion-content">
                        <padding><Insets top="0" right="24" bottom="32" left="24"/></padding>

                        <!-- Instructional Callout -->
                        <HBox style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 12;" spacing="12">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <Region minWidth="4" maxWidth="4" style="-fx-background-color: -fx-primary; -fx-background-radius: 4px;"/>
                            <Label text="Generate an API token in your Atlassian account settings to enable task syncing. This connection remains encrypted within the Monolith core." wrapText="true" style="-fx-text-fill: -fx-on-surface-variant; -fx-font-size: 12px; -fx-font-weight: 600;" />
                        </HBox>

                        <!-- Input Form -->
                        <VBox spacing="16">
                            <!-- URL Field -->
                            <VBox spacing="8">
                                <Label text="JIRA INSTANCE URL" styleClass="form-label-flat"/>
                                <TextField fx:id="urlField" promptText="https://your-domain.atlassian.net" styleClass="form-input-flat"/>
                            </VBox>

                            <!-- Email Field -->
                            <VBox spacing="8">
                                <Label text="EMAIL ADDRESS" styleClass="form-label-flat"/>
                                <TextField fx:id="emailField" promptText="admin@company.com" styleClass="form-input-flat"/>
                            </VBox>

                            <!-- API Token Field -->
                            <VBox spacing="8">
                                <Label text="API TOKEN" styleClass="form-label-flat"/>
                                <StackPane alignment="CENTER_RIGHT" styleClass="form-input-flat-container">
                                    <PasswordField fx:id="tokenFieldMasked" promptText="Paste token here" styleClass="form-input-flat-transparent"/>
                                    <TextField fx:id="tokenFieldVisible" promptText="Paste token here" styleClass="form-input-flat-transparent" visible="false"/>
                                    <Button styleClass="fab-icon-button" onAction="#toggleTokenVisibility" style="-fx-padding: 0 12 0 0;">
                                        <graphic>
                                            <FontIcon fx:id="visibilityIcon" iconLiteral="fltfal-eye-show-20" iconSize="20" style="-fx-icon-color: -fx-outline-variant;"/>
                                        </graphic>
                                    </Button>
                                </StackPane>
                            </VBox>
                        </VBox>

                        <!-- Status Message -->
                        <Label fx:id="statusLabel" wrapText="true" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

                        <!-- Action Button -->
                        <Button fx:id="connectButton" text="AUTHORIZE CONNECTION" styleClass="primary-button-flat" onAction="#handleConnect" maxWidth="Infinity" />

                    </VBox>
                </VBox>

            </VBox>

        </VBox>
    </ScrollPane>

    <!-- Top Navigation Bar (Highest Z-Order) -->
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" styleClass="glass-bar" StackPane.alignment="TOP_CENTER" maxHeight="80.0" pickOnBounds="false">
        <padding>
            <Insets left="24" right="24"/>
        </padding>
        <Button styleClass="fab-icon-button" onAction="#handleBack" style="-fx-padding: 0;">
            <graphic>
                <FontIcon iconLiteral="fltral-arrow-left-20" iconSize="24" styleClass="menu-icon"/>
            </graphic>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="MONOLITH" styleClass="font-manrope tracking-widest" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: -fx-primary; -fx-text-transform: uppercase;" />
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Spacer for symmetry -->
        <Region prefWidth="24"/>
    </HBox>

</StackPane>
