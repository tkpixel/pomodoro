<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:id="overlayRoot" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.signongroup.pomodoro.view.jira.CreateIssueViewController"
           style="-fx-background-color: #000000CC;" pickOnBounds="true">

    <VBox maxWidth="576.0" style="-fx-background-color: -fx-surface; -fx-background-radius: 12; -fx-border-color: rgba(73,72,71,0.15); -fx-border-radius: 12; -fx-border-width: 1;"
          StackPane.alignment="CENTER" maxHeight="-Infinity" effect="${null}">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #131313; -fx-padding: 16 24;"
              styleClass="top-rounded">
            <FontIcon iconLiteral="fltral-grid-24" iconSize="24" style="-fx-icon-color: -fx-primary;"/>
            <Label text="New Issue" style="-fx-font-family: 'Manrope'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-primary;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#handleCancel" style="-fx-background-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                <graphic>
                    <FontIcon iconLiteral="fltfal-dismiss-24" iconSize="20" style="-fx-icon-color: -fx-on-surface-variant;"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Form Content -->
        <VBox spacing="20" style="-fx-padding: 24;">

            <!-- Project Selector -->
            <VBox spacing="8">
                <Label text="PROJECT" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: rgba(73,72,71,0.1); -fx-border-radius: 12;">
                    <StackPane style="-fx-background-color: rgba(255,143,112,0.1); -fx-background-radius: 8;" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fltfal-folder-24" iconSize="20" style="-fx-icon-color: -fx-primary;"/>
                    </StackPane>
                    <Label fx:id="projectLabel" text="EMBER FOCUS" style="-fx-font-family: 'Manrope'; -fx-font-size: 14px; -fx-font-weight: 900; -fx-text-fill: -fx-on-surface; -fx-text-transform: uppercase;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <FontIcon iconLiteral="fltral-chevron-right-24" iconSize="20" style="-fx-icon-color: -fx-on-surface-variant;"/>
                </HBox>
            </VBox>

            <!-- Summary -->
            <VBox spacing="8">
                <Label text="SUMMARY TITLE" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                <TextField fx:id="summaryField" promptText="Add an title..."
                           style="-fx-background-color: -fx-surface-container-highest; -fx-background-radius: 8; -fx-padding: 16 20; -fx-font-family: 'Manrope'; -fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: -fx-on-surface; -fx-prompt-text-fill: rgba(173,170,170,0.4); -fx-border-width: 0;"/>
            </VBox>

            <!-- Icons Row -->
            <HBox spacing="16" style="-fx-padding: 0 0 16 0; -fx-border-color: transparent transparent #2C2C2E transparent; -fx-border-width: 0 0 1 0;">
                <!-- Issue Type -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="ISSUE TYPE" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                    <ComboBox fx:id="issueTypeComboBox" maxWidth="Infinity" style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 8; -fx-font-family: 'Inter'; -fx-font-size: 12px; -fx-font-weight: 500; -fx-text-fill: -fx-on-surface-variant;"/>
                </VBox>
                <!-- Priority -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="PRIORITY" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                    <ComboBox fx:id="priorityComboBox" maxWidth="Infinity" style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 8; -fx-font-family: 'Inter'; -fx-font-size: 12px; -fx-font-weight: 500; -fx-text-fill: -fx-on-surface-variant;"/>
                </VBox>
                <!-- Assignee -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="ASSIGNEE" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 8; -fx-padding: 8;">
                        <StackPane style="-fx-background-color: #ff7852; -fx-background-radius: 12;" prefWidth="24" prefHeight="24">
                            <Label text="ME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #480d00;"/>
                        </StackPane>
                        <Label text="ME" style="-fx-font-family: 'Inter'; -fx-font-size: 12px; -fx-font-weight: 500; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Description -->
            <VBox spacing="8">
                <Label text="DESCRIPTION" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                <TextArea fx:id="descriptionArea" promptText="Context or technical details..." wrapText="true" prefRowCount="3"
                          style="-fx-background-color: -fx-surface-container-low; -fx-control-inner-background: -fx-surface-container-low; -fx-background-radius: 8; -fx-padding: 16; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-text-fill: -fx-on-surface; -fx-prompt-text-fill: rgba(173,170,170,0.4); -fx-border-width: 0;"/>
            </VBox>

            <!-- Estimation -->
            <HBox spacing="16" style="-fx-padding: 16 0 0 0; -fx-border-color: #2C2C2E transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="STORY POINTS" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                    <HBox alignment="CENTER" spacing="8">
                        <Button onAction="#handleDecrementStoryPoints" style="-fx-background-color: -fx-surface-container-high; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                            <graphic><FontIcon iconLiteral="fltfal-line-horizontal-1-20" iconSize="14" style="-fx-icon-color: -fx-on-surface;"/></graphic>
                        </Button>
                        <TextField fx:id="storyPointsField" alignment="CENTER" style="-fx-background-color: transparent; -fx-font-family: 'Manrope'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface; -fx-border-width: 0;"/>
                        <Button onAction="#handleIncrementStoryPoints" style="-fx-background-color: -fx-surface-container-high; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                            <graphic><FontIcon iconLiteral="fltfal-add-20" iconSize="14" style="-fx-icon-color: -fx-on-surface;"/></graphic>
                        </Button>
                    </HBox>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="ORIGINAL ESTIMATE" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-text-transform: uppercase;"/>
                    <StackPane alignment="CENTER_RIGHT">
                        <TextField fx:id="originalEstimateField" promptText="2d 4h" style="-fx-background-color: -fx-surface-container-low; -fx-background-radius: 8; -fx-padding: 12 36 12 12; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-text-fill: -fx-on-surface; -fx-prompt-text-fill: rgba(173,170,170,0.4); -fx-border-width: 0;"/>
                        <FontIcon iconLiteral="fltfal-clock-24" iconSize="14" style="-fx-icon-color: -fx-on-surface-variant;" StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin>
                                <Insets right="12"/>
                            </StackPane.margin>
                        </FontIcon>
                    </StackPane>
                </VBox>
            </HBox>

        </VBox>

        <!-- Footer -->
        <HBox alignment="CENTER" spacing="16" style="-fx-background-color: -fx-surface-container-low; -fx-padding: 16 24;"
              styleClass="bottom-rounded">
            <Button text="CANCEL" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: -fx-on-surface-variant; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <CheckBox fx:id="createAnotherCheckBox" text="CREATE ANOTHER" style="-fx-font-family: 'Inter'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface-variant; -fx-cursor: hand;"/>
            <Button fx:id="createButton" text="Create Issue" onAction="#handleCreate" style="-fx-background-color: -fx-primary; -fx-text-fill: #480d00; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 12 32; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,143,112,0.3), 24, 0, 0, 12);"/>
        </HBox>
    </VBox>
</StackPane>
