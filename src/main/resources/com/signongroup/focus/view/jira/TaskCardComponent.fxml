<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<fx:root type="javafx.scene.layout.VBox" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
         style="-fx-background-color: #1C1C1E; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: transparent; -fx-border-radius: 16; -fx-border-width: 1;"
         fx:id="cardRoot" spacing="12">

    <!-- Header: Epic Badge and Avatar -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="epicBadge" style="-fx-background-color: #1a1919; -fx-text-fill: -fx-primary; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-transform: uppercase;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Avatar Placeholder -->
        <StackPane fx:id="avatarContainer" prefWidth="24" prefHeight="24" style="-fx-background-radius: 12; -fx-border-color: #1a1919; -fx-border-radius: 12; -fx-background-color: -fx-surface-container-highest;">
             <Label fx:id="assigneeInitials" style="-fx-font-size: 8px; -fx-font-weight: bold;"/>
        </StackPane>
    </HBox>

    <!-- Title and ID/Priority -->
    <HBox alignment="TOP_LEFT" spacing="10">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="taskTitle" wrapText="true" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -fx-on-surface;"/>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <!-- Fallback Priority Icon -->
                <FontIcon fx:id="priorityIcon" iconSize="12" managed="false" visible="false"/>
                <!-- Issue Type Icon (Fetched from Jira) -->
                <StackPane fx:id="issueTypeContainer" style="-fx-background-radius: 2; -fx-background-color: transparent; -fx-padding: 0;">
                     <javafx.scene.image.ImageView fx:id="issueTypeIcon" fitWidth="14" fitHeight="14" preserveRatio="true"/>
                </StackPane>
                <Label fx:id="taskKey" style="-fx-font-size: 10px; -fx-text-fill: -fx-on-surface-variant; -fx-font-family: 'Inter';"/>
            </HBox>
        </VBox>
        <FontIcon fx:id="completedIcon" iconLiteral="fltral-checkmark-circle-20" iconSize="20" styleClass="icon-success" visible="false" managed="false"/>
    </HBox>

    <!-- Story Points Badge (Shown if no estimate) -->
    <HBox fx:id="storyPointsContainer" alignment="CENTER_LEFT" managed="false" visible="false">
         <Label fx:id="storyPointsLabel" style="-fx-font-size: 10px; -fx-text-fill: -fx-on-surface-variant;"/>
    </HBox>

    <!-- Details Container (Expandable) -->
    <VBox fx:id="detailsContainer" spacing="12" managed="false" visible="false">
        <!-- Progress Bar Section (Only for In Progress with Estimation) -->
        <VBox fx:id="progressContainer" spacing="8" style="-fx-background-color: #131313; -fx-background-radius: 16; -fx-padding: 16;" managed="false" visible="false">
            <HBox alignment="CENTER_LEFT">
                <Label text="PROGRESS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -fx-primary; -fx-text-transform: uppercase; -fx-letter-spacing: 0.1em;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="progressPercentage" style="-fx-font-size: 10px; -fx-text-fill: -fx-on-surface-variant;"/>
            </HBox>
            <StackPane alignment="CENTER_LEFT">
                <Region style="-fx-background-color: #262626; -fx-background-radius: 4; -fx-pref-height: 6;"/>
                <Region fx:id="progressBarFill" style="-fx-background-color: -fx-primary; -fx-background-radius: 4; -fx-pref-height: 6;"/>
            </StackPane>
        </VBox>

        <!-- Footer Actions (Play Button) -->
        <HBox fx:id="actionContainer" alignment="CENTER_LEFT" spacing="10" managed="false" visible="false">
            <Button fx:id="playButton" style="-fx-background-color: -fx-primary; -fx-background-radius: 20; -fx-min-width: 40; -fx-min-height: 40;" onAction="#handlePlayAction">
                <graphic>
                    <FontIcon iconLiteral="fltfmz-play-20" iconSize="20" styleClass="icon-dark"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>

</fx:root>
